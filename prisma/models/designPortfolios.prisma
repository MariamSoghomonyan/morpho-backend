model DesignPortfolio {
  id        String @id @default(uuid())
  lang      String
  title     String
  designBtn String

  items DesignPortfolioItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DesignPortfolioItem {
  id         String @id @default(uuid())
  image      String?

  portfolioId String
  portfolio   DesignPortfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}