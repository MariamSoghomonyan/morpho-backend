model AboutChoose {
  id        String              @id @default(uuid())
  lang      String
  badge     String
  title     String
  items     AboutChooseItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AboutChooseItem {
  id         String         @id @default(uuid())
  title      String

  chooseId   String
  choose     AboutChoose @relation(fields: [chooseId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}