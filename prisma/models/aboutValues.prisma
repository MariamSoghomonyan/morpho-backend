  model aboutValues {
    id        String   @id @default(uuid())
    lang      String
    badge     String
    title     String
    about_btn String

    items     aboutValueItems[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
  }

  model aboutValueItems {
    id        String   @id @default(uuid())
    title     String
    order     Int      @default(0)

    aboutId   String
    about     aboutValues @relation(fields: [aboutId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
  }