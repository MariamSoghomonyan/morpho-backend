    <input type="text" name="lang" required />

    <h2>TABS</h2>

    <div id="tabs-container"></div>

    <button type="button" id="add-tab" class="submit submenu">Add tab</button>

    <button type="submit" class="submit">Create</button>
  </form>
</div>

<script src="/js/designCategories.js"></script>
