<div class="action">
  <h1><%= title.charAt(0).toUpperCase() + title.slice(1).toLowerCase() %></h1>

  <form action="/admin/<%= activeRoute %>/edit/<%= data.id %>" method="post">

    <label>Language</label>
    <input type="text" name="lang" value="<%= data.lang %>" />

    <label>Title</label>
    <input type="text" name="title" value="<%= data.title %>" />

    <label>Route</label>
    <input type="text" name="route" value="<%= data.route %>" />

    <h2>SUBMENUS</h2>

    <div id="submenu-container">
      <% data.dropdowns.forEach(d => { %>
        <div class="submenu-row">

          <div class="submenu-fields">
            <input type="text" name="dropdown_title[]" value="<%= d.title %>" />
            <input type="text" name="dropdown_route[]" value="<%= d.route %>" />
          </div>

          <div class="submenu-actions">
            <button type="button" class="remove-btn">✖</button>
          </div>

        </div>
      <% }) %>
    </div>

    <button type="button" id="add-submenu" class="submit submenu">
      Add submenu
    </button>

    <button type="submit" class="submit">Update</button>
  </form>
</div>

<script src="/js/submenu.js"></script>