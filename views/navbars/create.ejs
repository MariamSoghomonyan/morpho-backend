<div class="action">
  <h1><%= title.charAt(0).toUpperCase() + title.slice(1).toLowerCase() %></h1>

  <form action="/admin/<%= activeRoute %>/add" method="post">
    <label>Language<span>*</span></label>
    <input type="text" name="lang" required />

    <label>Title<span>*</span></label>
    <input type="text" name="title" required />

    <h2>SUBMENUS</h2>

    <div id="submenu-container"></div>

    <button type="button" id="add-submenu" class="submit submenu">
      Add submenu
    </button>

    <button type="submit" class="submit">Create</button>
  </form>
</div>

<script src="/js/submenu.js"></script>
