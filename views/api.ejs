<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/api.css">
    <title><%= title %></title>
</head>
<body>
    <div class="api-page">
        <h1 class="title"><%= title %></h1>
        <h2 class="endpoints-title">Endpoints</h2>

        <ul class="api-list">
            <% if (data && data.length) { %>
                <% data.forEach(function(elem) { %>
                    <li>
                        <a href="<%= elem %>" target="_blank"><%= elem %></a>
                    </li>
                <% }) %>
            <% } else { %>
                <li>No endpoints found</li>
            <% } %>
        </ul>
    </div>
</body>
</html>