<div class="action">
  <h1><%= title.charAt(0).toUpperCase() + title.slice(1).toLowerCase() %></h1>

  <form action="/admin/<%= activeRoute %>/edit/<%= data.id %>" method="post">
    <label>Language</label>
    <input type="text" name="lang" value="<%= data.lang %>" required />

    <label>Title</label>
    <input type="text" name="title" value="<%= data.title %>" />

    <label>Description</label>
    <input type="text" name="descr" value="<%= data.descr %>" />

    <label>Button Text</label>
    <input
      type="text"
      name="consultation_btn"
      value="<%= data.consultation_btn %>"
      required
    />

    <button type="submit" class="submit">Update</button>
  </form>
</div>
